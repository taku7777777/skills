+import { CouponService } from "./CouponService";
+
+it("applies a coupon", async () => {
+  const repository = {
+    findById: async () => ({
+      id: "coupon-1",
+      ownerId: "user-1",
+      amount: 300,
+      expiresAt: new Date("2030-01-01T00:00:00Z"),
+    }),
+    save: async () => undefined,
+  };
+  const service = new CouponService(repository);
+
+  await expect(
+    service.applyCoupon("user-1", 1000, "coupon-1", new Date("2029-01-01T00:00:00Z")),
+  ).resolves.toEqual({
+    couponId: "coupon-1",
+    originalPrice: 1000,
+    finalPrice: 700,
+    discount: 300,
+  });
+});
