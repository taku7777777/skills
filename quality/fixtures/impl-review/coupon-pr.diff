@@ -0,0 +1,12 @@
+export type Coupon = {
+  id: string;
+  ownerId: string;
+  amount: number;
+  expiresAt: Date;
+  usedAt?: Date;
+};
+
+export interface CouponRepository {
+  findById(id: string): Promise<Coupon | undefined>;
+  save(coupon: Coupon): Promise<void>;
+}
diff --git a/src/coupons/CouponService.ts b/src/coupons/CouponService.ts
new file mode 100644
index 0000000..94b14fc
--- /dev/null
+++ b/src/coupons/CouponService.ts
@@ -0,0 +1,41 @@
+import { CouponRepository } from "./CouponRepository";
+
+export type DiscountResult = {
+  couponId: string;
+  originalPrice: number;
+  finalPrice: number;
+  discount: number;
+};
+
+export class CouponService {
+  constructor(private readonly coupons: CouponRepository) {}
+
+  async applyCoupon(
+    userId: string,
+    productPrice: number,
+    couponId: string,
+    now = new Date(),
+  ): Promise<DiscountResult> {
+    const coupon = await this.coupons.findById(couponId);
+    if (!coupon) {
+      throw new Error("coupon not found");
+    }
+    if (coupon.usedAt) {
+      throw new Error("coupon already used");
+    }
+    if (coupon.expiresAt < now) {
+      throw new Error("coupon expired");
+    }
+
+    const finalPrice = Math.round((productPrice - coupon.amount) * 100) / 100;
+    coupon.usedAt = now;
+    await this.coupons.save(coupon);
+
+    return {
+      couponId,
+      originalPrice: productPrice,
+      finalPrice,
+      discount: coupon.amount,
+    };
+  }
+}
